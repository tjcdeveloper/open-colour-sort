<?xml version="1.0" encoding="utf-8"?>
<!-- PRIVACY.md commits that game state never leaves the device. allowBackup
     ="false" stops cloud backup, but on API 31+ device-to-device transfer
     needs these rules too: exclude everything from both channels. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
    </device-transfer>
</data-extraction-rules>
